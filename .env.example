# Frontend (Vite) environment variables.
# These are the only two the browser needs, and both are safe to expose: the
# anon key is a public key whose access is controlled by Row Level Security.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# The Gemini API key is deliberately NOT listed here. Anything prefixed with
# VITE_ is compiled into the public browser bundle, so putting an AI key in the
# frontend would leak it to anyone who opens dev tools. The key lives server-side
# as a Supabase Edge Function secret named GEMINI_API_KEY - see
# supabase/AI_SETUP.md for how to set it.
